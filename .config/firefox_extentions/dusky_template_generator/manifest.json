{
  "manifest_version": 2,
  "name": "Dusky Template Generator",
  "version": "1.1.0",
  "description": "Rapidly extract website CSS variables and visually theme, hide, or pick elements for Dusky Sites.",
  "browser_specific_settings": {
    "gecko": {
      "id": "dusky_template_generator@dusk.com"
    }
  },
  "permissions": [
    "<all_urls>",
    "activeTab",
    "tabs",
    "nativeMessaging",
    "storage",
    "clipboardWrite",
    "webNavigation",
    "downloads"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Dusky Template Generator"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
