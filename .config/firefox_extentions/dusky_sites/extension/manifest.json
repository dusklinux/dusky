{
  "manifest_version": 3,
  "name": "Dusky Sites",
  "version": "2.0.2",
  "description": "Dynamic webpage and browser theming using Matugen colors",
  "homepage_url": "https://github.com/dusklinux/dusky",
  "browser_specific_settings": {
    "gecko": {
      "id": "dusky_sites@dusk.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "theme"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "defaults.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Dusky Sites"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}