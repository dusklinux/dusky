# ==============================================================================
# function: logs (detailed_log)
# description: The ultimate, zero-regression execution and logging wrapper.
# deployment: Production-ready for mass distribution.
# ==============================================================================
logs() {
    emulate -L zsh
    setopt local_options NO_NOMATCH PIPE_FAIL NO_MULTIOS
    umask 077

    local -i opt_strace=0 opt_quiet=0 opt_strict=0 opt_journal=0
    local opt_outdir="" opt_timeout=""
    local raw_target="" script_exec_path="" script_resolved_path="" script_name="" script_dir="" bash_bin=""
    local -a script_args=()

    local c_red="" c_yellow="" c_green="" c_blue="" c_bold="" c_reset=""
    if [[ -t 2 && "${TERM:-}" != "dumb" ]]; then
        c_red=$'\e[31m'; c_yellow=$'\e[33m'; c_green=$'\e[32m'; c_blue=$'\e[34m'; c_bold=$'\e[1m'; c_reset=$'\e[0m'
    fi

    # --- 1. Robust Option Parsing
    while (( $# )); do
        case "$1" in
            -h|--help)
                printf 'Usage: logs [opts] <script> [args...]\n'
                printf '  -s, --strace    Trace system calls (-f -tt -T -y -yy)\n'
                printf '  -q, --quiet     Suppress terminal output (logs only)\n'
                printf '  -S, --strict    Inject strict mode (set -euo pipefail)\n'
                printf '  -j, --journal   Capture journalctl entries after the run\n'
                printf '  -t, --timeout   Set max execution time (e.g., 30, 2m)\n'
                printf '  -o, --outdir    Specify custom output directory\n'
                return 0
                ;;
            -s|--strace) opt_strace=1; shift ;;
            -q|--quiet) opt_quiet=1; shift ;;
            -S|--strict) opt_strict=1; shift ;;
            -j|--journal) opt_journal=1; shift ;;
            -t|--timeout)
                shift
                if [[ ! "$1" =~ ^[0-9]+([.][0-9]+)?(s|m|h|d)?$ ]]; then
                    printf '%sError:%s -t requires a duration (e.g., 30s, 2m)\n' "$c_red" "$c_reset" >&2
                    return 2
                fi
                opt_timeout="$1"; shift 
                ;;
            --timeout=*) opt_timeout="${1#*=}"; shift ;;
            -o|--outdir)
                shift
                if (( $# == 0 )) || [[ "$1" == -* ]]; then
                    printf '%sError:%s -o requires a directory argument\n' "$c_red" "$c_reset" >&2
                    return 2
                fi
                opt_outdir="$1"; shift 
                ;;
            --outdir=*) opt_outdir="${1#*=}"; shift ;;
            --) shift; break ;;
            -*) printf '%sError:%s Unknown option %s\n' "$c_red" "$c_reset" "$1" >&2; return 2 ;;
            *)  break ;;
        esac
    done

    if (( $# == 0 )); then
        printf '%sError:%s No script provided.\n' "$c_red" "$c_reset" >&2
        return 2
    fi

    raw_target="$1"; shift
    script_args=("$@")

    # --- 2. Hardened Path & Dependency Resolution
    if ! bash_bin=$(command -v bash 2>/dev/null); then
        printf '%sError:%s bash not found in PATH.\n' "$c_red" "$c_reset" >&2
        return 1
    fi

    if [[ "$raw_target" == */* ]]; then
        script_exec_path="$raw_target"
    elif [[ -e "$raw_target" ]]; then
        script_exec_path="$raw_target"
    elif (( $+commands[$raw_target] )); then
        script_exec_path="${commands[$raw_target]}"
    else
        printf '%sError:%s target not found: %s\n' "$c_red" "$c_reset" "$raw_target" >&2
        return 1
    fi

    if ! script_resolved_path=$(realpath -e -- "$script_exec_path" 2>/dev/null); then
        printf '%sError:%s could not resolve target: %s\n' "$c_red" "$c_reset" "$script_exec_path" >&2
        return 1
    fi

    local mime=$(file -b --mime-type "$script_resolved_path" 2>/dev/null)
    if [[ "$mime" != text/* && "$mime" != application/x-executable ]]; then
        printf '%sError:%s Target is a binary, not a shell script (MIME: %s)\n' "$c_red" "$c_reset" "$mime" >&2
        return 1
    fi

    script_name="${script_resolved_path:t}"
    script_dir="${script_resolved_path:h}"

    # --- 3. Collision-Proof Session Directory
    local ts=$(date '+%Y%m%d-%H%M%S')
    local base="${opt_outdir:-$HOME/Documents/logs/script_logs}"
    local outdir="${base%/}"
    mkdir -p -m 700 -- "$outdir"
    
    local session_dir
    session_dir=$(mktemp -d "${outdir}/${script_name}.${ts}.XXXXXX") || {
        printf '%sError:%s Failed to generate session directory.\n' "$c_red" "$c_reset" >&2
        return 1
    }

    local trace_log="${session_dir}/trace.log"
    local stdout_log="${session_dir}/stdout.log"
    local stderr_log="${session_dir}/stderr.log"
    local comb_log="${session_dir}/combined.log"
    local meta_log="${session_dir}/metadata.txt"
    local sys_log="${session_dir}/system_state.txt"
    local journal_log="${session_dir}/systemd_journal.log"
    local error_dump="${session_dir}/error_state_dump.txt"
    local snapshot_path="${session_dir}/script_snapshot.source"
    local env_prelude="${session_dir}/.bash_prelude.sh"
    local fifo_out="${session_dir}/fifo_out"
    local fifo_err="${session_dir}/fifo_err"
    local exit_code=0
    local pre_sha256="$(sha256sum -- "$script_resolved_path" 2>/dev/null | awk '{print $1}')"

    # ==========================================================================
    # ENCLOSING ZSH ALWAYS BLOCK - Guarantees Subshell-Immune Teardown
    # ==========================================================================
    {
        # --- 4. Pre-Flight Checks & Snapshots
        touch "$trace_log" "$stdout_log" "$stderr_log" "$comb_log"
        mkfifo -m 600 "$fifo_out" "$fifo_err"

        cp -a --reflink=auto -- "$script_resolved_path" "$snapshot_path" 2>/dev/null || cp -a -- "$script_resolved_path" "$snapshot_path"

        if ! "$bash_bin" -n -- "$script_resolved_path" > "${session_dir}/syntax_preflight.log" 2>&1; then
            printf '%s[!] CRITICAL:%s Bash syntax check failed. Execution aborted.\n' "$c_red" "$c_reset" >&2
            cat "${session_dir}/syntax_preflight.log" >&2
            exit_code=1
            return 1
        fi

        if (( $+commands[shellcheck] )); then
            shellcheck --shell=bash -x -- "$script_resolved_path" > "${session_dir}/shellcheck_preflight.log" 2>&1
        fi

        local j_cursor=""
        if (( opt_journal )) && (( $+commands[journalctl] )); then
            j_cursor=$(journalctl -n 0 --show-cursor -q 2>/dev/null | awk '{print $NF}')
        fi

        # --- 5. BASH_ENV Payload Injection
        cat >"$env_prelude" <<'EOF'
unset BASH_ENV

if [[ -n "${DL_TRACE_LOG:-}" ]]; then
    if exec {__dl_xtrace_fd}>>"$DL_TRACE_LOG" 2>/dev/null; then
        BASH_XTRACEFD=$__dl_xtrace_fd
    fi
fi

if [[ "${DL_STRICT:-0}" == "1" ]]; then
    set -o errexit -o nounset -o pipefail
    shopt -s inherit_errexit 2>/dev/null || true
fi

set -o errtrace -o functrace
__DL_TRAP_FIRED=0

__dl_err() {
    local _ret=$?
    local -a _pipe_status=("${PIPESTATUS[@]}")  
    local _trigger="${1:-}"

    if [[ "$_trigger" == "EXIT" && "$_ret" == 0 ]]; then return 0; fi

    local is_fatal=0
    [[ "$_trigger" == "EXIT" ]] || [[ "$-" == *e* ]] && is_fatal=1

    if (( ! is_fatal )); then
        builtin echo -e "\e[1;33m[WARN] Unchecked command failed (Exit $_ret): ${BASH_COMMAND:-unknown}\e[0m" >&2
        return 0
    fi

    [[ "$__DL_TRAP_FIRED" == "1" ]] && return 0
    __DL_TRAP_FIRED=1

    local _cmd="${BASH_COMMAND:-unknown}"
    local _src="${BASH_SOURCE[1]:-${BASH_SOURCE[0]:-unknown}}"
    local _lin="${BASH_LINENO[0]:-?}"
    
    set +e +u 
    set +o pipefail 2>/dev/null || true

    if [[ -n "${DL_ERROR_DUMP:-}" ]]; then
        {
            printf '=== CRITICAL ERROR AT %s ===\n' "$(date '+%H:%M:%S.%N')"
            printf 'Exit Code: %s\nCommand: %s\n' "$_ret" "$_cmd"
            printf 'PIPESTATUS: ( %s )\n' "${_pipe_status[*]}"
            printf '\n--- OPEN FILE DESCRIPTORS (/proc/%s/fd) ---\n' "$BASHPID"
            ls -l "/proc/$BASHPID/fd" 2>/dev/null || true
            printf '\n--- VARIABLE STATE (declare -p) ---\n'
            declare -p 2>/dev/null | awk -F= 'BEGIN {IGNORECASE=1} {k=$1; if (k ~ /(^|_)(PASS(WORD)?|TOKEN|SECRET|API[_-]?KEY|ACCESS[_-]?KEY|PRIVATE[_-]?KEY|AUTH|CREDENTIAL|COOKIE|SESSION)(_|$)/) {print k "=[REDACTED]"} else {print $0}}' || true
        } >> "$DL_ERROR_DUMP"
    fi

    builtin echo -e "\n\e[1;41m  SCRIPT ERROR DETECTED  \e[0m" >&2
    builtin echo -e "\e[1;31m Exit Code:\e[0m $_ret \e[37m| PIPESTATUS: ( ${_pipe_status[*]} )\e[0m" >&2
    builtin echo -e "\e[1;31m Command  :\e[0m $_cmd" >&2
    builtin echo -e "\e[1;33m Call Stack:\e[0m" >&2
    local frame=0
    while builtin caller $frame; do ((frame++)); done | awk '{printf "  \033[36m↳\033[0m %s:%s (\033[35m%s\033[0m)\n", $3, $1, $2}' >&2
    
    if [[ -f "$_src" && "$_lin" =~ ^[0-9]+$ ]]; then
        builtin echo -e "\e[1;33m Source Context:\e[0m" >&2
        awk -v n="$_lin" 'NR >= n - 3 && NR <= n + 3 { printf "  %s %6d | %s\n", (NR == n ? "\033[1;31m>\033[0m" : "  "), NR, $0 }' "$_src" >&2
    fi
    builtin echo -e "\n\e[1;34m [!] Full variable and FD state dumped to: \e[4m$(basename "$DL_ERROR_DUMP")\e[0m\n" >&2
}

trap '__dl_err ERR' ERR
trap '__dl_err EXIT' EXIT

set -o xtrace
EOF

        # --- 6. Metadata Capture
        {
            printf 'session_start=%s\n' "$(date --iso-8601=seconds)"
            printf 'script_path=%s\n' "$script_resolved_path"
            printf 'user=%s uid=%d\n' "$USER" "$UID"
            printf 'host=%s kernel=%s\n' "${HOST:-$(hostname)}" "$(uname -r)"
            printf 'bash_version=%s\n' "$($bash_bin --version | head -n1)"
            printf 'source_sha256_before=%s\n' "$pre_sha256"
            
            local -a fstat=( $(stat -c '%a %s' -- "$script_resolved_path" 2>/dev/null || echo "000 0") )
            printf 'mode=%s size=%s\n' "${fstat[1]}" "${fstat[2]}"
            
            if (( $+commands[git] )) && git -C "$script_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
                printf 'git_branch=%s\n' "$(git -C "$script_dir" rev-parse --abbrev-ref HEAD)"
                printf 'git_commit=%s\n' "$(git -C "$script_dir" rev-parse HEAD)"
                printf 'git_dirty=%s\n'  "$(git -C "$script_dir" status --porcelain | grep -q . && echo 'true' || echo 'false')"
            else
                printf 'git_context=none\n'
            fi
            
            printf 'args=('
            (( ${#script_args} )) && printf ' %q' "${script_args[@]}"
            printf ' )\n'
        } > "$meta_log" 2>/dev/null

        {
            echo "=== INITIAL SYSTEM STATE ==="
            uptime; echo
            free -m; echo
            df -hT / /home 2>/dev/null; echo
            lscpu | awk '/^(Model name|CPU\(s\)|Thread\(s\) per core):/ { print }'; echo
            echo "=== INITIAL ENVIRONMENT ==="
            env | LC_ALL=C sort | awk -F= 'BEGIN {IGNORECASE=1} {k=$1; if (k ~ /(^|_)(PASS(WORD)?|TOKEN|SECRET|API[_-]?KEY|ACCESS[_-]?KEY|PRIVATE[_-]?KEY|AUTH|CREDENTIAL|COOKIE|SESSION)(_|$)/) {print k "=[REDACTED]"} else {print $0}}'
        } > "$sys_log" 2>/dev/null

        (( opt_quiet )) || printf 'Session Logging Active: %s%s%s\n' "$c_blue" "$session_dir" "$c_reset" >&2

        # --- 7. Execution Assembly
        local -a cmd_prefix=()
        if [[ -x /usr/bin/time ]]; then
            cmd_prefix+=( /usr/bin/time -v -o "${session_dir}/resource_usage.log" )
        fi
        if [[ -n "$opt_timeout" ]] && (( $+commands[timeout] )); then
            cmd_prefix+=( timeout --foreground "$opt_timeout" )
        fi
        if (( opt_strace )) && (( $+commands[strace] )); then
            cmd_prefix+=( strace -f -tt -T -y -yy -s 1024 -o "${session_dir}/strace_dump" )
        fi

        # Start asynchronous logging daemons on the FIFOs (Fixing the unquoted string split bug)
        local -a t_cmd=( tee -a )
        if [[ -x "/usr/bin/stdbuf" ]]; then
            t_cmd=( /usr/bin/stdbuf -i0 -o0 -e0 tee -a )
        fi

        if (( opt_quiet )); then
            < "$fifo_out" "${t_cmd[@]}" "$stdout_log" >> "$comb_log" &
            local out_pid=$!
            < "$fifo_err" "${t_cmd[@]}" "$stderr_log" >> "$comb_log" &
            local err_pid=$!
        else
            < "$fifo_out" "${t_cmd[@]}" "$stdout_log" "$comb_log" &
            local out_pid=$!
            < "$fifo_err" "${t_cmd[@]}" "$stderr_log" "$comb_log" >&2 &
            local err_pid=$!
        fi

        # --- 8. The Direct Execution Trigger
        (
            export BASH_ENV="$env_prelude"
            export DL_TRACE_LOG="$trace_log"
            export DL_ERROR_DUMP="$error_dump"
            export DL_STRICT="$opt_strict"
            export PS4='+[$EPOCHREALTIME] [PID:$$/SUB:$BASHPID] [${BASH_SOURCE[0]##*/}:${LINENO:-0}:${FUNCNAME[0]:-MAIN}] '

            exec "${cmd_prefix[@]}" "$bash_bin" "$script_resolved_path" "${script_args[@]}" > "$fifo_out" 2> "$fifo_err"
        ) &
        local child_pid=$!
        
        wait "$child_pid"
        exit_code=$?

        # --- 9. Anti-Orphan-Hang Teardown
        ( sleep 0.5; kill $out_pid $err_pid 2>/dev/null ) &
        local flush_killer=$!
        wait $out_pid $err_pid 2>/dev/null || true
        kill $flush_killer 2>/dev/null || true

        # --- 10. Finalization
        local post_sha256="$(sha256sum -- "$script_resolved_path" 2>/dev/null | awk '{print $1}')"
        printf 'session_end=%s\n' "$(date --iso-8601=seconds)" >> "$meta_log" 2>/dev/null
        printf 'exit_code=%d\n' "$exit_code" >> "$meta_log" 2>/dev/null
        printf 'source_sha256_after=%s\n' "$post_sha256" >> "$meta_log" 2>/dev/null

        if (( opt_journal )) && [[ -n "$j_cursor" ]]; then
            journalctl --after-cursor="$j_cursor" > "$journal_log" 2>/dev/null
            [[ -s "$journal_log" ]] || rm -f -- "$journal_log"
        fi

        if (( ! opt_quiet )); then
            echo "" >&2
            if (( exit_code == 0 )); then
                printf 'Result: %sSUCCESS%s (0)\n' "$c_green" "$c_reset" >&2
            elif (( exit_code == 124 )) && [[ -n "$opt_timeout" ]]; then
                printf 'Result: %sTIMED OUT%s (124) - Terminated after %s\n' "$c_yellow" "$c_reset" "$opt_timeout" >&2
            else
                printf 'Result: %sFAILED%s (%d) -> Check %s/stderr.log\n' "$c_red" "$c_reset" "$exit_code" "$session_dir" >&2
            fi
            printf 'Artifacts stored at: %s%s%s\n' "$c_bold" "$session_dir" "$c_reset" >&2
            
            [[ -f "${session_dir}/trace.log" ]] && printf '  ├─ trace.log           (Step-by-step Bash traces)\n' >&2
            [[ -f "$journal_log" ]] && printf '  ├─ systemd_journal.log (Kernel/System events captured!)\n' >&2
            [[ -f "${session_dir}/resource_usage.log" ]] && printf '  ├─ resource_usage.log  (GNU Time profiling)\n' >&2
            [[ -f "$error_dump" ]] && printf '  ├─ error_state_dump.txt (Crash variable & FD state)\n' >&2
            printf '  └─ script_snapshot.source (Immutable code copy)\n' >&2
        fi

    } always {
        # The ultimate guarantee: Subshells CANNOT execute this block.
        # It will only trigger once, safely, when the entire wrapper concludes.
        rm -f -- "$env_prelude" "$fifo_out" "$fifo_err" 2>/dev/null
    }

    return $exit_code
}
