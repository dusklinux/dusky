# =============================================================================
# Dusky Package Installer & Search (pkg_search)
# Exposes a dynamic, interactive FZF installer utilizing paru, yay, or pacman.
# =============================================================================

pkg_search() {
    # 1. Dependency Validation
    if (( ! $+commands[fzf] )); then
        print -u2 -P "\n%F{red}✖ Error:%f 'fzf' is not installed."
        return 1
    fi

    # 2. Package Manager Detection & Configuration
    local helper=""
    local helper_path=""
    local -a list_cmd
    local -a install_cmd

    if (( $+commands[paru] )); then
        helper="paru"
        helper_path="$commands[paru]"
        list_cmd=(paru -Sl)
        install_cmd=(paru -S)
    elif (( $+commands[yay] )); then
        helper="yay"
        helper_path="$commands[yay]"
        list_cmd=(yay -Sl)
        install_cmd=(yay -S)
    else
        helper="pacman"
        helper_path="$commands[pacman]"
        list_cmd=(pacman -Sl)
        install_cmd=(sudo pacman -S)
    fi

    # 3. Dynamic Theme Sourcing & Color Conversions
    local theme_file="$HOME/.config/matugen/generated/dusky_tui.json"
    local fzf_colors=""
    local success_hex="#8dd2da" # Fallback green/teal
    local success_ansi=""

    if [[ -f "$theme_file" ]]; then
        local -A theme
        while read -r key val; do
            theme[$key]="$val"
        done < <(awk -F'"' '/"(bg|fg|accent|error|warning|success|muted)":/ {print $2, $4}' "$theme_file")

        success_hex="${theme[success]}"

        fzf_colors="bg+:${theme[bg]},bg:${theme[bg]},spinner:${theme[accent]}"
        fzf_colors+=",fg:${theme[fg]},fg+:${theme[fg]},header:${theme[accent]},info:${theme[warning]}"
        fzf_colors+=",pointer:${theme[accent]},marker:${theme[success]},prompt:${theme[accent]}"
        fzf_colors+=",hl:${theme[error]},hl+:${theme[error]},border:${theme[muted]},label:${theme[success]}"
    else
        # Fallback theme (Catppuccin Mocha)
        fzf_colors="bg+:#1e1e2e,bg:#11111b,spinner:#f5e0dc"
        fzf_colors+=",fg:#cdd6f4,fg+:#cdd6f4,header:#89b4fa,info:#cba6f7"
        fzf_colors+=",pointer:#a6e3a1,marker:#f5e0dc,prompt:#cba6f7"
        fzf_colors+=",hl:#f38ba8,hl+:#f38ba8,border:#585b70,label:#a6e3a1"
    fi

    # Convert success hex to ANSI escape sequence (24-bit color) for list checkmarks
    local hex="${success_hex#\#}"
    local r=$(( 16#${hex[1,2]} ))
    local g=$(( 16#${hex[3,4]} ))
    local b=$(( 16#${hex[5,6]} ))
    success_ansi="\033[38;2;${r};${g};${b}m"

    # 4. Compile Live Help Overlay, Headers, and Preview Scripts
    local visual_header
    visual_header=$(printf "\033[1;37mST\033[0m\033[38;5;238m│\033[0m\033[1;37m             PACKAGE              \033[0m\033[38;5;238m│\033[0m\033[38;5;242m REPOSITORY\033[0m")

    export DUSKY_PKG_SEARCH_HELP='clear; printf "\n\n  \033[1;38;5;81m󰏖 Dusky Package Installer - Keyboard Shortcuts\033[0m\n  \033[38;5;238m────────────────────────────────────────────────────\033[0m\n  \033[1;33m[TAB]\033[0m       Select Multiple Packages (Toggle)\n  \033[1;33m[ALT-C]\033[0m     Copy Package Name to Clipboard\n  \033[1;33m[CTRL-P]\033[0m    Toggle Preview Window (Show/Hide)\n  \033[1;33m[CTRL-D]\033[0m    Scroll Preview Window Down\n  \033[1;33m[CTRL-U]\033[0m    Scroll Preview Window Up\n  \033[1;33m[F1]\033[0m        Show this Help Menu\n  \033[1;33m[ESC]\033[0m       Exit Search\n  \033[1;33m[ENTER]\033[0m     Install Selected Packages\n\n  \033[38;5;242mPress any key to return...\033[0m"; read -rsn1'

    export DUSKY_INPKG_PREVIEW='
export LC_ALL=C
pkg="$1"
helper="'"$helper_path"'"

# Dynamic Status Badge (Installed vs Available)
if pacman -Q "$pkg" >/dev/null 2>&1; then
    status_str="\e[1;32mInstalled\e[0m"
else
    status_str="\e[1;34mAvailable\e[0m"
fi

cols=${FZF_PREVIEW_COLUMNS:-80}
hr=$(printf "%*s" "$cols" "" | sed "s/ /─/g")

printf "\033[1;38;5;81m:: \033[1;37mPackage Info: \033[1;32m%s\033[0m\n\033[38;5;238m%s\033[0m\n" "$pkg" "$hr"
printf "\033[1;38;5;39m%-16s\033[0m: %b\n" "Status" "$status_str"

# Run sync info query and format output nicely
"$helper" -Sii "$pkg" 2>/dev/null | awk -F":" '\''
    function print_kv(key, val, color) {
        printf "\033[1;38;5;39m%-16s\033[0m: \033[38;5;%sm%s\033[0m\n", key, color, val
    }
    {
        key = $1; sub(/[ \t]+$/, "", key)
        val = $2; for(i=3; i<=NF; i++) val = val ":" $i
        sub(/^[ \t]+/, "", val)
    }
    key == "Repository"      { print_kv("Repository", val, val == "aur" ? "203" : "213") }
    key == "Version"         { print_kv("Version", val, "220") }
    key == "Description"     { print_kv("Description", val, "253") }
    key == "Architecture"    { print_kv("Architecture", val, "141") }
    key == "URL"             { print_kv("URL", val, "114") }
    key == "AUR URL"         { print_kv("AUR URL", val, "114") }
    key == "Download Size"   { print_kv("Download Size", val, "115") }
    key == "Installed Size"  { print_kv("Installed Size", val, "115") }
    key == "Depends On"      { print_kv("Dependencies", val, val == "None" ? "242" : "250") }
    key == "Make Deps"       { print_kv("Make Deps", val, val == "None" ? "242" : "250") }
    key == "Check Deps"      { print_kv("Check Deps", val, val == "None" ? "242" : "250") }
    key == "Optional Deps"   { print_kv("Optional Deps", val, val == "None" ? "242" : "250") }
    key == "Conflicts With"  { print_kv("Conflicts", val, val == "None" ? "242" : "196") }
    key == "Replaces"        { print_kv("Replaces", val, val == "None" ? "242" : "208") }
    key == "Maintainer"      { print_kv("Maintainer", val, "242") }
    key == "Packager"        { print_kv("Packager", val, "242") }
    key == "Build Date"      { print_kv("Built", val, "250") }
    key == "First Submitted" { print_kv("Submitted", val, "250") }
    key == "Last Modified"   { print_kv("Modified", val, "250") }
    key == "Votes"           { print_kv("Votes", val, "220") }
    key == "Popularity"      { print_kv("Popularity", val, "220") }
'\''
'

    # 5. Execution via interactive FZF (using modern v0.74+ structures)
    local -a pkgs
    pkgs=(${(f)"$("${list_cmd[@]}" | sort -t ' ' -k2,2 -u | awk -v success_color="$success_ansi" -F' ' '
        {
            repo = $1
            pkg = $2
            is_installed = ($4 == "[installed]" || $5 == "[installed]")

            status = is_installed ? (success_color "✓\033[0m") : " "
            
            disp_name = (length(pkg) > 32) ? substr(pkg, 1, 29) "..." : pkg
            
            visual_str = sprintf("%s \033[38;5;238m│\033[0m \033[1;38;5;39m%-32s\033[0m \033[38;5;238m│\033[0m \033[38;5;242m%s\033[0m", status, disp_name, repo)
            
            printf "%s|%s\n", pkg, visual_str
        }
    ' | fzf --multi --ansi \
        --delimiter='\|' \
        --with-nth=2 \
        --prompt=" 󰏖 Search Packages ❯ " \
        --pointer="" \
        --marker="✓" \
        --layout=reverse \
        --border=rounded \
        --border-label=" Dusky Package Installer ($helper) [F1: Help] " \
        --border-label-pos=3 \
        --preview-label=" Package Metadata " \
        --preview-label-pos=bottom \
        --header="$visual_header" \
        --header-first \
        --bind="ctrl-p:toggle-preview" \
        --bind="ctrl-d:preview-page-down" \
        --bind="ctrl-u:preview-page-up" \
        --bind="alt-c:execute-silent(echo -n {1} | wl-copy)+change-prompt( 󰏖 Copied Package Name! ❯ )" \
        --bind="f1:execute(bash -c \"\$DUSKY_PKG_SEARCH_HELP\")" \
        --color="$fzf_colors" \
        --preview='bash -c "$DUSKY_INPKG_PREVIEW" _ {1}' \
        --preview-window="right,60%,border-left,wrap")"})

    # Cleanup environment variables
    unset DUSKY_INPKG_PREVIEW
    unset DUSKY_PKG_SEARCH_HELP

    # 6. Install Selected Packages
    local -a targets
    for pkg_line in "${pkgs[@]}"; do
        if [[ -n "$pkg_line" ]]; then
            targets+=("${pkg_line%%|*}")
        fi
    done

    if (( ${#targets} )) && [[ -n "${targets[1]}" ]]; then
        print -P "\n%F{blue}::%f %BInstalling packages via $helper:%b ${targets[*]}"
        "${install_cmd[@]}" "${targets[@]}"
    else
        print -P "\n%F{yellow}⚠%f No packages selected for installation."
    fi
}
